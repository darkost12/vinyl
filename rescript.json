{
  "name": "vinyl",
  "bsc-flags": [
    "-bs-no-version-header",
    "-bs-super-errors",
    "-open JsonCombinators",
    "-open RCore"
  ],
  "jsx": {
    "version": 4,
    "mode": "classic"
  },
  "bs-dependencies": [
    "@glennsl/rescript-json-combinators",
    "@rescript/react",
    "@rescript/core",
    "@rescript-mui/material",
    "rescript-nodejs"
  ],
  "sources": [
    {
      "dir": "src",
      "subdirs": true
    }
  ],
  "package-specs": {
    "module": "esmodule"
  },
  "suffix": ".mjs",
  "warnings": {
    "number": "+A-3-4-9-40-42-44-102-20",
    "error": "+A"
  }
}
